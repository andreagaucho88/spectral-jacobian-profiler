%% arxiv.sty -- lightweight "A Preprint" arXiv-style layout.
%% Self-contained; depends only on packages shipped with a standard TeX Live.
%% Usage:  \documentclass{article}\usepackage{arxiv}
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{arxiv}[2026/07/06 v1.0 arXiv preprint style]

\RequirePackage[letterpaper,margin=1in]{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{xcolor}
\RequirePackage{titlesec}
\RequirePackage{lmodern}

% ---------------------------------------------------------------------------
% Running header: "<short title>" on the left, "A Preprint" on the right,
% separated from the body by a thin rule; page number centred in the footer.
% ---------------------------------------------------------------------------
\newcommand{\@arxivrunning}{A Preprint}
\newcommand{\headertitle}[1]{\renewcommand{\@arxivrunning}{#1}}

\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.4pt}
\fancyhead[L]{\itshape\small\@arxivrunning}
\fancyhead[R]{\itshape\small A\ {\scshape Preprint}}
\fancyfoot[C]{\small\thepage}
\fancypagestyle{plain}{% title page
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[C]{\small\thepage}%
}

% ---------------------------------------------------------------------------
% Section headings: bold, slightly larger, arXiv-preprint flavour.
% ---------------------------------------------------------------------------
\titleformat{\section}{\normalfont\large\bfseries}{\thesection}{0.6em}{}
\titleformat{\subsection}{\normalfont\normalsize\bfseries}{\thesubsection}{0.6em}{}
% \paragraph is left as the default run-in bold heading (arXiv-preprint flavour).

% ---------------------------------------------------------------------------
% Abstract: rule above and below, gently indented, matching the arXiv look.
% ---------------------------------------------------------------------------
\renewenvironment{abstract}{%
  \par\vspace{0.5em}%
  \noindent\rule{\linewidth}{0.4pt}\par\vspace{4pt}%
  \begin{center}\bfseries\large Abstract\end{center}\vspace{-2pt}%
  \begingroup\leftskip=1.2em\rightskip=1.2em\small%
}{%
  \par\endgroup\vspace{4pt}%
  \noindent\rule{\linewidth}{0.4pt}\par\vspace{0.8em}%
}

% ---------------------------------------------------------------------------
% \keywords{...}
% ---------------------------------------------------------------------------
\providecommand{\keywords}[1]{%
  \vspace{0.3em}\noindent{\small\textbf{Keywords:}\ \ #1}\par\vspace{0.4em}}

\endinput
